{
    "name": "abdasis/laravel-rapidapi",
    "description": "Laravel wrapper untuk RapidAPI - konsumsi ribuan API dengan mudah",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Abd. Asis",
            "email": "abdasis@users.noreply.github.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0|^4.0",
        "orchestra/testbench": "^9.0|^10.0",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "psr-4": {
            "Abdasis\\LaravelRapidApi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Abdasis\\LaravelRapidApi\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Abdasis\\LaravelRapidApi\\RapidApiServiceProvider"
            ],
            "aliases": {
                "RapidApi": "Abdasis\\LaravelRapidApi\\Facades\\RapidApi"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
